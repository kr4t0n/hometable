# Copy to `.env` and adjust. Never commit `.env`.

# ── App ───────────────────────────────────────────────────────────────
ENV=development

# ── Database (Postgres) ───────────────────────────────────────────────
# Matches the docker-compose "db" service.
DATABASE_URL=postgresql+psycopg://hometable:hometable@localhost:5432/hometable

# ── Object storage (S3-compatible / MinIO) ────────────────────────────
# Endpoint the BACKEND uses to reach the object store (server-side calls).
S3_ENDPOINT_URL=http://localhost:9000
# Endpoint used to SIGN presigned URLs — must be reachable by the BROWSER.
# In k8s this is your MinIO ingress/route, NOT the in-cluster service DNS.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=hometable-media
S3_REGION=us-east-1

# ── Media ─────────────────────────────────────────────────────────────
MEDIA_PRESIGN_EXPIRY=3600   # presigned URL lifetime, seconds
MAX_UPLOAD_MB=512           # max single upload size

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=http://localhost:5173
